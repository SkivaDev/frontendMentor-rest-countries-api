---
import { isDarkMode } from "../store.js";
---

<header class='w-full bg-elements text-color-text'>
  <div class="flex justify-between items-center w-full h-[78px] px-[80px]">
    <h1 class="text-[21px] font-semibold tracking-[1.9px] ml-1">Where in the world?</h1>
    <button id="theme-toggle-btn" class=" flex justify-center items-center gap-3">
      <img alt="theme icon" />
      <span class="">Dark mode</span>
    </button>
  </div>
</header>

<script>
  import { isDarkMode } from "../store.js";
  // Set the store to true when the button is clicked
  function openDialog() {
    isDarkMode.set(!isDarkMode.value);
  }

  // Add an event listener to the button
  const themeToggleButton = document.getElementById("theme-toggle-btn");
  if (themeToggleButton) {
    themeToggleButton.addEventListener("click", openDialog);
  }


// Listen to changes in the store, and dark/light theme accordingly
isDarkMode.subscribe((dark) => {
    const themeIcon = document.querySelector("#theme-toggle-btn img") as HTMLImageElement;
    if (themeIcon) {
        if (dark) {
            themeIcon.src = './mode-dark.svg';
        } else {
            themeIcon.src = './mode-light.svg';
        }
    }
});
</script>
